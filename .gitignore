# Python 缓存
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg
*.csv

# 数据集与处理后的数据
data/
dataset/
student_model/
log/
opencompass_data/
*.json
*.jsonl

# 模型输出、日志、检查点
outputs/
*.pt
*.jinja
*.safetensors
# 评估结果
eval_results/

# IDE 配置
.vscode/

# 环境变量（含 token）
.env
config.yaml
